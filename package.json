{
  "name": "kiby",
  "version": "2.2.0",
  "description": "Kiby is a Discord virtual pet experience where players care for Kirby companions in a persistent social leaderboard.",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed:npcs": "node src/scripts/seedNpcs.js",
    "seed:npcs:reset": "node src/scripts/seedNpcs.js --reset",
    "test": "jest --runInBand",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.9.0",
    "dotenv": "^16.0.3",
    "mongoose": "^7.3.3",
    "pretty-ms": "^8.0.0",
    "topgg-autoposter": "^2.0.1"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^2.0.22",
    "prettier": "^3.4.2"
  }
}
