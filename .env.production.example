# Discord bot token
TOKEN=replace_with_discord_bot_token

# MongoDB connection string
MONGO_CONNECTION=mongodb://username:password@host:27017/kiby?authSource=admin

# Optional Top.gg API key for autoposting stats
TOPGG_KEY=

# Runtime environment
NODE_ENV=production
LOG_LEVEL=info

# Health endpoint port
HEALTH_PORT=8080

# Optional list of developer Discord user IDs (comma-separated)
DEV_USER_IDS=123456789012345678,987654321098765432

# Optional guild ID for command registration/testing
TEST_GUILD_ID=

# Care simulation settings
CARE_TICK_MINUTES=30
NEGLECT_THRESHOLD_MINUTES=60
NOTIFICATION_THRESHOLD=30
WORLD_EVENT_CHANCE_PERCENT=8
GLOBAL_EVENT_DURATION_HOURS=24
GLOBAL_EVENT_GOAL=120
SEASON_LENGTH_DAYS=7

# Default sleep schedule applied to new players
DEFAULT_SLEEP_TIMEZONE=UTC
DEFAULT_SLEEP_START=23:00
DEFAULT_SLEEP_DURATION_HOURS=8

# NPC simulation settings
NPC_ENABLED=true
NPC_TOTAL=28
NPC_CASUAL=18
NPC_ACTIVE=10
NPC_COMPETITIVE=0
NPC_TICK_MINUTES=60

# Revive/economy/social settings
REVIVE_BASE_COST=160
REVIVE_LEVEL_MULTIPLIER=22
GIFT_DAILY_COIN_CAP=300
GIFT_DAILY_ITEM_CAP=12
GIFT_TRANSFER_FEE_PERCENT=5
AMBIENT_BEHAVIOR_CHANCE_PERCENT=10
AMBIENT_BEHAVIOR_COOLDOWN_MINUTES=360
ADVENTURE_FAIL_THRESHOLD_HP=25
ADVENTURE_MIN_START_HP=60

# Max player-selected Kirby name length
MAX_KIRBY_NAME_LENGTH=24
