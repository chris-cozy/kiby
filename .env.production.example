# Discord bot token
TOKEN=replace_with_discord_bot_token

# MongoDB connection string
MONGO_CONNECTION=mongodb://username:password@host:27017/kiby?authSource=admin

# Optional Top.gg API key for autoposting stats
TOPGG_KEY=

# Runtime environment
NODE_ENV=production
LOG_LEVEL=info

# Health endpoint port
HEALTH_PORT=8080

# Optional list of developer Discord user IDs (comma-separated)
DEV_USER_IDS=123456789012345678,987654321098765432

# Optional guild ID for command registration/testing
TEST_GUILD_ID=

# Core simulation settings
CARE_TICK_MINUTES=30
NEGLECT_THRESHOLD_MINUTES=60
NOTIFICATION_THRESHOLD=30
WORLD_EVENT_CHANCE_PERCENT=8
SEASON_LENGTH_DAYS=7

# Global campaign event settings
GLOBAL_EVENT_DURATION_MIN_HOURS=24
GLOBAL_EVENT_DURATION_MAX_HOURS=72
GLOBAL_EVENT_IDLE_GAP_MIN_HOURS=24
GLOBAL_EVENT_IDLE_GAP_MAX_HOURS=48
GLOBAL_EVENT_START_CHANCE_PER_TICK_PERCENT=35
GLOBAL_EVENT_ACTIVE_PLAYER_WINDOW_HOURS=24
GLOBAL_EVENT_TARGET_PER_ACTIVE=12
GLOBAL_EVENT_GOAL_MIN=24
GLOBAL_EVENT_GOAL_MAX=2000

# Default sleep schedule applied to new players
DEFAULT_SLEEP_TIMEZONE=UTC
DEFAULT_SLEEP_START=23:00
DEFAULT_SLEEP_DURATION_HOURS=8

# NPC simulation settings
NPC_ENABLED=true
NPC_TOTAL=20
NPC_CASUAL=18
NPC_ACTIVE=2
NPC_COMPETITIVE=0
NPC_TICK_MINUTES=60

# Revive/economy settings
REVIVE_BASE_COST=160
REVIVE_LEVEL_MULTIPLIER=22
GIFT_DAILY_COIN_CAP=300
GIFT_DAILY_ITEM_CAP=12
GIFT_TRANSFER_FEE_PERCENT=5
SOCIAL_RECEIVE_COOLDOWN_MINUTES=45

# Ambient behavior
AMBIENT_BEHAVIOR_CHANCE_PERCENT=10
AMBIENT_BEHAVIOR_COOLDOWN_MINUTES=360

# Adventure and battle power tuning
ADVENTURE_FAIL_THRESHOLD_HP=25
ADVENTURE_ETA_VARIANCE_PERCENT=25
ADVENTURE_BP_WEIGHT_PERCENT=70
ADVENTURE_CONDITION_WEIGHT_PERCENT=30
BATTLE_POWER_TRAIN_MIN_GAIN=12
BATTLE_POWER_TRAIN_MAX_GAIN=18
BATTLE_POWER_DECAY_PERCENT_PER_DAY=3

# Kiby language progression tuning
LANGUAGE_EXPOSURE_PER_UNLOCK=4
LANGUAGE_XP_PER_EXPOSURE=2
LANGUAGE_XP_PER_LEVEL=120

# Max player-selected Kirby name length
MAX_KIRBY_NAME_LENGTH=24
